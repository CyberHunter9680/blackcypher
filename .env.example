# ─────────────────────────────────────────────────────────────────
# BlackCypher - Environment Variables
# Copy this file as .env and fill in your real credentials
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon DB) ──────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── Firebase (optional - for Google Sign In & Phone OTP) ─────────
# Get from: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Email OTP (Gmail SMTP) ────────────────────────────────────────
# 1. Enable 2FA on your Gmail account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate an App Password (select "Mail" + "Windows Computer")
SMTP_EMAIL=your-gmail@gmail.com
SMTP_APP_PASS=xxxx xxxx xxxx xxxx

# ── SMS OTP (Fast2SMS - Free Indian SMS Service) ──────────────────
# 1. Register at https://www.fast2sms.com
# 2. Go to Dev API → API Key
# 3. Make sure you have credits (free plan gives some on signup)
FAST2SMS_API_KEY=your_fast2sms_api_key_here
